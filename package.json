{
  "name": "messengerapp",
  "productName": "Centrio",
  "version": "1.5.21",
  "description": "All messengers in one app",
  "author": {
    "name": "Centrio",
    "email": "support@centrio.me"
  },
  "main": "main.js",
  "scripts": {
    "build:renderer": "node build-renderer.js",
    "watch:renderer": "node build-renderer.js --watch",
    "start": "npm run build:renderer && electron .",
    "dev": "npm run build:renderer && electron .",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "rimraf dist && npm run build:renderer && electron-builder --win",
    "build:mac": "rimraf dist && npm run build:renderer && electron-builder --mac",
    "build:linux": "rimraf dist && npm run build:renderer && electron-builder --linux",
    "publish": "npm run build:win && node scripts/publish.js"
  },
  "devDependencies": {
    "electron": "^36.4.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.12",
    "rimraf": "^6.1.3",
    "scp2": "^0.5.0",
    "ssh2-sftp-client": "^12.1.1"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "auto-launch": "^5.0.6",
    "axios": "^1.14.0",
    "dotenv": "^17.4.1",
    "electron-log": "^5.4.3",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.8.3",
    "sound-play": "^1.1.0"
  },
  "build": {
    "appId": "me.centrio.app",
    "productName": "Centrio",
    "copyright": "Copyright © 2026 Centrio",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!dist-*/**/*",
      "!landing/**/*",
      "!node_modules/.cache/**/*",
      "!*.md",
      "!*.log",
      "!.git/**/*",
      "!.github/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/logotype.ico"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64"] }
      ],
      "icon": "assets/logo.png",
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "Centrio ${version}",
      "icon": "assets/logo.png",
      "window": { "width": 540, "height": 380 }
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "icon": "assets/logo.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Centrio"
    },
    "asarUnpack": [
      "assets/sounds/**/*"
    ],
    "publish": {
      "provider": "generic",
      "url": "https://download.centrio.me/"
    },
    "protocols": [
      {
        "name": "centrio-auth",
        "schemes": [
          "centrio-auth"
        ]
      }
    ]
  }
}

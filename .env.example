# Google OAuth (для входа через Google)
GOOGLE_DESKTOP_CLIENT_ID=your_google_client_id
GOOGLE_DESKTOP_CLIENT_SECRET=your_google_client_secret

# Yandex OAuth (для входа через Яндекс)
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret

# Telegram Bot (для уведомлений)
TELEGRAM_BOT_ID=your_telegram_bot_id

# Сервер загрузок (для публикации релизов)
UPLOAD_HOST=your_server_ip
UPLOAD_PORT=22
UPLOAD_USER=root
UPLOAD_PASSWORD=your_password
UPLOAD_PATH=/var/www/centrio-downloads
